{
  "name": "hvdc-ontology-chatgpt-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ChatGPT Apps SDK + MCP server for HVDC ontology-grounded logistics answers.",
  "scripts": {
    "generate:worker-assets": "python scripts/generate_worker_assets.py",
    "dev": "npm run generate:worker-assets && wrangler dev",
    "start": "npm run dev",
    "node:dev": "npm run generate:worker-assets && tsx server/src/index.ts",
    "claude:dev": "mcp-remote https://hvdc-ontology-chatgpt-app.mscho715.workers.dev/mcp",
    "claude:start": "mcp-remote https://hvdc-ontology-chatgpt-app.mscho715.workers.dev/mcp",
    "claude:stdio": "mcp-remote https://hvdc-ontology-chatgpt-app.mscho715.workers.dev/mcp",
    "claude:local": "tsx server/src/claude-server.ts",
    "typecheck": "npm run generate:worker-assets && tsc --noEmit",
    "test": "npm run generate:worker-assets && vitest run --exclude \"docs/archive/**\" --exclude \".claude/**\" --exclude \".claire/**\"",
    "report:sct-card": "tsx scripts/report-sct-card.ts",
    "audit:source-pii": "node scripts/audit-source-corpus-pii.mjs",
    "scan:sct-pii": "node scripts/scan-sct-card-pii.mjs",
    "index": "python scripts/index_corpus.py",
    "worker:dry-run": "npm run generate:worker-assets && wrangler deploy --dry-run",
    "worker:deploy": "npm run verify && wrangler deploy",
    "cloudflare:deploy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy_cloudflare.ps1",
    "d1:seed-control-tower": "python scripts/seed_control_tower_d1.py --remote",
    "d1:seed-wh-status": "python scripts/seed_wh_status_d1.py --remote",
    "d1:seed-wh-status:dry": "python scripts/seed_wh_status_d1.py --dry-run",
    "d1:reconcile-wh-status": "python scripts/reconcile_wh_status_d1.py",
    "d1:rollback-wh-status:dry": "python scripts/rollback_wh_status_ingest.py --ingest-id",
    "seed:local": "SEED_DRY_RUN=false tsx scripts/seed-d1.ts",
    "seed:remote": "SEED_DRY_RUN=false tsx scripts/seed-d1.ts --remote",
    "seed:dry": "SEED_DRY_RUN=true tsx scripts/seed-d1.ts",
    "test:coverage": "npm run generate:worker-assets && vitest run --coverage --exclude \"docs/archive/**\" --exclude \".claude/**\"",
    "verify": "npm run typecheck && npm test && npm run worker:dry-run",
    "verify:governance": "npm run report:sct-card && npm run scan:sct-pii && npm run audit:source-pii && node --check scripts/serve-widget-smoke.mjs && node --check scripts/scan-sct-card-pii.mjs && node --check scripts/audit-source-corpus-pii.mjs && npx vitest run tests/intent-router.test.ts tests/decision-card.test.ts tests/pipeline.test.ts tests/sct-operating-contract.test.ts tests/widget.test.ts tests/p2-zero-gate.test.ts --exclude \"docs/archive/**\" --exclude \".claude/**\" --exclude \".claire/**\"",
    "verify:bindings": "tsx scripts/verify-bindings.ts",
    "verify:seed": "tsx scripts/verify-seed.ts",
    "verify:full": "npm run verify:bindings && npm run verify:seed"
  },
  "dependencies": {
    "@microlabs/otel-cf-workers": "1.0.0-rc.52",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.20.2",
    "@opentelemetry/api": "^1.9.0",
    "agents": "^0.12.3",
    "tsx": "^4.20.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^3.2.0",
    "mcp-remote": "^0.1.38",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.90.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
