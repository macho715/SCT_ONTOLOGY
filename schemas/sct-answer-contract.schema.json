{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sct-ontology.local/schemas/sct-answer-contract.schema.json",
  "title": "SCT Answer Contract",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "verdict",
    "summary",
    "evidence",
    "evidenceIds",
    "validationStatus",
    "validation",
    "actions",
    "decisionCard",
    "humanGateRequired",
    "audit"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["DIAGNOSTIC", "PASS", "PASS_WITH_FINDINGS", "DRAFT_READY", "AMBER", "NEEDS_INPUT", "PENDING_APPROVAL", "DRY_RUN_ONLY", "INFO", "WARN", "BLOCK", "NO_EVIDENCE", "ZERO"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "businessImpact": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "docId", "sectionPath", "snippet", "sourceType", "evidenceScore"],
        "properties": {
          "id": { "type": "string" },
          "docId": { "type": "string" },
          "sectionPath": { "type": "string" },
          "snippet": { "type": "string" },
          "evidenceScore": {
            "type": "object",
            "required": [
              "evidenceId",
              "intentRelevance",
              "domainSpecificity",
              "directSupport",
              "authorityLevel",
              "operationalActionability",
              "recency",
              "finalScore",
              "supportState"
            ],
            "properties": {
              "evidenceId": { "type": "string" },
              "intentRelevance": { "type": "number" },
              "domainSpecificity": { "type": "number" },
              "directSupport": { "type": "number" },
              "authorityLevel": { "type": "number" },
              "operationalActionability": { "type": "number" },
              "recency": { "type": "number" },
              "finalScore": { "type": "number" },
              "supportState": {
                "type": "string",
                "enum": ["SUPPORTED", "PARTIAL", "NO_DIRECT_EVIDENCE", "CONTRADICTED"]
              }
            }
          },
          "sourceType": { "type": "string" }
        }
      }
    },
    "evidenceIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validationStatus": {
      "type": "string",
      "enum": ["PASS", "INFO", "WARN", "BLOCK", "NO_EVIDENCE", "AMBER", "ZERO"]
    },
    "validation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ruleId", "reasonCode", "status", "evidenceIds", "message"],
        "properties": {
          "ruleId": { "type": "string" },
          "reasonCode": { "type": "string" },
          "status": { "type": "string" },
          "evidenceIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "message": { "type": "string" }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["actionType", "ownerRole", "humanGateRequired"],
        "properties": {
          "actionType": { "type": "string" },
          "ownerRole": { "type": "string" },
          "humanGateRequired": { "type": "boolean" },
          "auditRecordRequired": { "type": "boolean" },
          "writeBackMode": {
            "type": "string",
            "enum": ["READ_ONLY", "DRY_RUN", "APPROVAL_REQUIRED", "WRITE", "AUDIT_RECORD", "BLOCKED"]
          },
          "parameters": { "type": "object" }
        }
      }
    },
    "decisionCard": {
      "type": "object",
      "required": [
        "schemaVersion",
        "intent",
        "intentGroup",
        "verdict",
        "severity",
        "primaryReason",
        "nextAction",
        "blockedBy",
        "allowedNow",
        "blockedUntilApproved",
        "humanGateState",
        "evidenceCoverage",
        "actions",
        "trace"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "sct.card.v2"
        },
        "intent": {
          "type": "string",
          "enum": [
            "SYSTEM_DIAGNOSTIC",
            "ONTOLOGY_PATCH_REVIEW",
            "CARD_RENDERING_AUDIT",
            "RULEPACK_GAP_ANALYSIS",
            "ROUTER_QA",
            "EVIDENCE_QA",
            "SCHEMA_BOUNDARY_REVIEW",
            "VALIDATION_POLICY_REVIEW",
            "LOGISTICS_DECISION",
            "EMAIL_DRAFT",
            "COST_GUARD",
            "DOCUMENT_GUARDIAN",
            "GENERAL_ANSWER"
          ]
        },
        "intentGroup": {
          "type": "string",
          "enum": ["SYSTEM_QA", "OPERATIONAL"]
        },
        "verdict": {
          "type": "string",
          "enum": ["DIAGNOSTIC", "PASS", "PASS_WITH_FINDINGS", "DRAFT_READY", "AMBER", "NEEDS_INPUT", "PENDING_APPROVAL", "DRY_RUN_ONLY", "WARN", "BLOCK", "ZERO"]
        },
        "severity": {
          "type": "string",
          "enum": ["P0", "P1", "P2"]
        },
        "primaryReason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        },
        "blockedBy": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ruleId", "ruleName", "reason", "requiredInputs", "missingInputs", "blockedActions", "severity"],
            "properties": {
              "ruleId": { "type": "string" },
              "ruleName": { "type": "string" },
              "reason": { "type": "string" },
              "requiredInputs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "missingInputs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blockedActions": {
                "type": "array",
                "items": { "type": "string" }
              },
              "severity": { "type": "string", "enum": ["P0", "P1", "P2"] }
            }
          }
        },
        "allowedNow": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blockedUntilApproved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "humanGateState": {
          "type": "string",
          "enum": [
            "READ_ONLY",
            "DRY_RUN",
            "APPROVAL_REQUESTED",
            "APPROVED_ACTION",
            "EXECUTED",
            "AUDITED",
            "DENIED",
            "CANCELLED",
            "EXPIRED",
            "NEEDS_REVIEW"
          ]
        },
        "evidenceCoverage": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["domain", "status", "required", "available", "directSupportRatio"],
            "properties": {
              "domain": { "type": "string" },
              "status": { "type": "string", "enum": ["PASS", "WARN", "BLOCK"] },
              "required": { "type": "number" },
              "available": { "type": "number" },
              "directSupportRatio": { "type": "number" }
            }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actionId", "ownerRole", "actionType", "requiredInput", "allowedNow", "blockedUntilApproved", "humanGateRequired", "auditRecordRequired", "writeBackMode", "approvalRequired", "approvalStatus", "status", "dueBasis"],
            "properties": {
              "actionId": { "type": "string" },
              "ownerRole": { "type": "string" },
              "actionType": { "type": "string" },
              "requiredInput": { "type": ["string", "null"] },
              "allowedNow": {
                "type": "array",
                "items": { "type": "string" }
              },
              "blockedUntilApproved": {
                "type": "array",
                "items": { "type": "string" }
              },
              "humanGateRequired": { "type": "boolean" },
              "auditRecordRequired": { "type": "boolean" },
              "writeBackMode": {
                "type": "string",
                "enum": ["READ_ONLY", "DRY_RUN", "APPROVAL_REQUIRED", "WRITE", "AUDIT_RECORD", "BLOCKED"]
              },
              "approvalRequired": { "type": "boolean" },
              "approvalStatus": {
                "type": "string",
                "enum": ["NotRequired", "Pending", "Approved", "Rejected", "Expired"]
              },
              "status": {
                "type": "string",
                "enum": ["Open", "Pending Input", "Pending Approval", "Done", "Rejected", "Expired", "Unassigned"]
              },
              "dueBasis": { "type": "string" }
            }
          }
        },
        "trace": {
          "type": "object",
          "required": ["sourceHash", "rulePackVersion", "rulePackIds", "rulePackExecution", "promptVersion", "approvalStatus", "generatedAt", "routeId"],
          "properties": {
            "sourceHash": { "type": "string" },
            "rulePackVersion": { "type": "string" },
            "rulePackIds": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rulePackExecution": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["rulePackId", "fired", "skippedReason", "evidenceOnly", "blockedByRuleId"],
                "properties": {
                  "rulePackId": { "type": "string" },
                  "fired": { "type": "boolean" },
                  "skippedReason": { "type": ["string", "null"] },
                  "evidenceOnly": { "type": "boolean" },
                  "blockedByRuleId": { "type": ["string", "null"] }
                }
              }
            },
            "promptVersion": { "type": "string" },
            "approvalActor": { "type": ["string", "null"] },
            "approvalStatus": {
              "type": "string",
              "enum": ["NotRequired", "Pending", "Approved", "Rejected", "Expired"]
            },
            "sensitiveAccessed": { "type": "boolean" },
            "generatedAt": { "type": "string" },
            "routeId": { "type": "string" }
          }
        }
      }
    },
    "resolvedEntities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["entityType", "identifierScheme", "identifierValue", "normalizedValue", "targetRid", "confidence"],
        "properties": {
          "entityType": {
            "type": "string",
            "enum": ["ShipmentUnit", "Document", "Invoice", "PersonRole", "Site", "SystemComponent", "Unknown"]
          },
          "identifierScheme": { "type": "string" },
          "identifierValue": { "type": "string" },
          "normalizedValue": { "type": "string" },
          "targetRid": { "type": ["string", "null"] },
          "confidence": { "type": "number" }
        }
      }
    },
    "graphPath": {
      "type": ["object", "null"],
      "required": ["startNode", "edges", "endNode", "pathConfidence"],
      "properties": {
        "startNode": { "type": "string" },
        "startNodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "relation", "to"],
            "properties": {
              "from": { "type": "string" },
              "relation": { "type": "string" },
              "to": { "type": "string" }
            }
          }
        },
        "riskEdges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "risk", "to", "severity"],
            "properties": {
              "from": { "type": "string" },
              "risk": { "type": "string" },
              "to": { "type": "string" },
              "severity": { "type": "string", "enum": ["INFO", "WARN", "BLOCK"] }
            }
          }
        },
        "operationalObjects": {
          "type": "array",
          "items": { "type": "string" }
        },
        "isMetaReview": { "type": "boolean" },
        "pathConfidence": { "type": "number" }
      }
    },
    "humanGateRequired": {
      "type": "boolean"
    },
    "audit": {
      "type": "object",
      "required": ["auditLogRequired", "sourceCoverage"],
      "properties": {
        "auditLogRequired": { "type": "boolean" },
        "sourceCoverage": {
          "type": "string",
          "enum": ["FULL", "PARTIAL", "NONE"]
        }
      }
    }
  }
}
